# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cu_market_intel

# Pool tuning (optional — defaults: size=5, overflow=10)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Data source API keys ───────────────────────────────────────────────────────
CENSUS_API_KEY=...          # https://api.census.gov/data/key_signup.html
# FDIC and NCUA public APIs do not require keys
# HMDA public API does not require a key

# ── Cache ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Frontend origin (CORS) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ── Mapbox (frontend choropleth maps) ─────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ── Email alerts ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=...
ALERT_FROM_ADDRESS=alerts@example.com
